# ============================================================
# AIOps Monitor · Docker Compose 环境变量
# 复制为 .env 并按需修改
# ============================================================

# 前端暴露端口（用户访问入口）
FRONTEND_PORT=8080

# 后端服务配置（容器内部通信，一般不需修改）
BACKEND_HOST=backend
BACKEND_PORT=8529

# 时区
TZ=Asia/Shanghai

# Go 运行时参数
GOMAXPROCS=4
