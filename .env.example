# ============================================================
# AIOps Monitor · Docker Compose 环境变量
# 复制为 .env 并按需修改
# ============================================================

# 前端暴露端口（用户访问入口）
FRONTEND_PORT=8080

# 后端服务配置（容器内部通信，一般不需修改）
BACKEND_HOST=backend
BACKEND_PORT=8529

# 时区
TZ=Asia/Shanghai

# Go 运行时参数
GOMAXPROCS=4

# 可选：LLM Gateway / SDK 结构化内容审计摄入令牌（至少 24 字符，生产使用随机密钥）
# 配置后可调用 POST /api/v1/integrations/content-audit；留空时接口保持禁用。
AIOPS_CONTENT_AUDIT_INGEST_TOKEN=
